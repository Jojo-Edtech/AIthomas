DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
HOST=127.0.0.1
PORT=8787

# Multi-user session isolation.
# ACCESS_MODE=anonymous lets anyone with the link use an isolated guest workspace.
# ACCESS_MODE=login keeps invite-only username/password sign-in.
# ACCESS_MODE=open is only for local development.
ACCESS_MODE=anonymous
SESSION_SECRET=replace_with_a_long_random_secret
SESSION_TTL_DAYS=7
ANONYMOUS_TTL_DAYS=30
COOKIE_SECURE=false

# Safety limits for the public chatbot backend.
MAX_REQUESTS_PER_HOUR=12
MAX_REQUESTS_PER_DAY=40
MAX_GLOBAL_REQUESTS_PER_DAY=120
MAX_ESTIMATED_TOKENS_PER_MONTH=800000
